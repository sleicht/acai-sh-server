# .env.example

# README
# how does env work?
# -> Default Secure & production ready; .env is only for dev overrides.
#
# All secrets should come from infra/.env.op
# Other overrides can go in infra/.env, which will be sourced by docker compose
# if you want to override a secret in .env.op, add `--env-file .env` to `op run`

### 1password Vault Config
# OP_VAULT_NAME and OP_ITEM_ID do not go in here, they go in `~/.env`

### Caddy config (infra/caddy/Caddyfile.devcontainer)
# devcontainer | devrelease | prod
CADDYFILE=devcontainer

### SMTP (for sending emails)
# email-delivery.SMTP.3
SMTP_RELAY=smtp.example.com
SMTP_USERNAME=inject_with_secret_manager
SMTP_PASSWORD=inject_with_secret_manager
SMTP_PORT=587
SMTP_SSL=false
SMTP_TLS=always
SMTP_CACERTFILE=/etc/ssl/certs/ca-certificates.crt
SMTP_AUTH=always
SMTP_RETRIES=2
SMTP_NO_MX_LOOKUPS=true

### Email sender configuration (for white-labeling)
# Display name in "From" field (defaults to your app name)
MAIL_FROM_NAME=My App
# Email address in "From" field (defaults to "noreply@{domain}" derived from URL_HOST)
MAIL_FROM_EMAIL=noreply@example.com

### Phoenix internal config
# Binding behind reverse-proxy (you probably don't need to change this - forward ports using caddy instead)
PHX_PORT=4000
# Set this to `true` only for releases, otherwise for dev we use `mix phx.server` instead. See runtime.exs.
START_SERVER=false

### URL configs
# app.example.com
URL_HOST=localhost
# Only for deploying app under a path e.g. `customer.com/forms/`, rebuild required - not runtime configurable. Default "/"
URL_PATH="/"
# https for prod, http for local
URL_SCHEME=http
# The port phoenix uses to generate URLs. Default/fallbacks are set in docker-compose.yml for prod/dev
URL_PORT=4000
# For multiple local devconatiners on same machine: change to prevent clash
HTTP_PORT=80
HTTPS_PORT=443
# fallback if empty is `infra`, which is docker's default as well (name of the directory)
INSTANCE_NAME=myapp-devpod-0
# Optional Plausible Analytics
PLAUSIBLE_SRC=https://plausible.io/js/<plausible_id>.js
### Database configs
# `acai_prod` | `acai_dev` | `acai_test`
POSTGRES_DB=acai_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=acai_postgres_data
POSTGRES_PASSWORD=inject_with_secret_manager
POSTGRES_USER=inject_with_secret_manager
SECRET_KEY_BASE=inject_with_secret_manager

### GitHub Image Registry
# username for account with read permissions for your registry image
GITHUB_USER=inject_with_secret_manager
# Classic Personal Access Token with 'packages:read'
# https://github.com/settings/tokens
GITHUB_PAT=inject_with_secret_manager

### Backup service config (not usually needed for local dev)
# Password for encrypting restic backups
RESTIC_PASSWORD=inject_with_secret_manager
# S3-compatible object storage credentials
AWS_ACCESS_KEY_ID=inject_with_secret_manager
AWS_SECRET_ACCESS_KEY=inject_with_secret_manager
# S3-compatible repository URL (e.g., s3:nbg1.your-objectstorage.com/bucket-name)
RESTIC_REMOTE_REPO=s3:region.your-objectstorage.com/example-bucket/dev-backups
AWS_DEFAULT_REGION=nbg1

### Backup Heartbeat (optional)
# URL to ping after successful backup (e.g. your monitoring provider)
BACKUP_HEARTBEAT_URL=https://uptime.example.com/api/v1/heartbeat/<heartbeat_id>
